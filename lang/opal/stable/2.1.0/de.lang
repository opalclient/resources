# Anti Bot
module.anti_bot.name=Anti Bot
module.anti_bot.description=Zusätzliche Bot-Überprüfung auf Servern wie Hypixel
module.anti_bot.basic_checks.name=Basic Checks
module.anti_bot.basic_checks.description=Gruppiert die leichten, pro-Spieler-Flags, die verwendet werden, um eine Entität als Bot für die Zielauswahl zu markieren.
module.anti_bot.tablist.name=Tablist
module.anti_bot.tablist.description=Markiert einen Spieler als Bot, wenn seine UUID in der Server-Tab-Liste fehlt.
module.anti_bot.no_gamemode.name=No GameMode
module.anti_bot.no_gamemode.description=Flags eines Spielers, die der Tab-Liste hinzugefügt wurden, ohne dass ein Spielmodus festgelegt wurde.
module.anti_bot.no_properties.name=No Properties
module.anti_bot.no_properties.description=Flags ein Spieler zum Tab-Verzeichnis, ohne Profilattribute wie beispielsweise Hautdaten.
module.anti_bot.illegal_pitch.name=Illegal Pitch
module.anti_bot.illegal_pitch.description=Markiert einen Spieler, dessen Kopfwinkel die normale 90-Grad-Grenze überschreitet.
module.anti_bot.illegal_health.name=Illegal Health
module.anti_bot.illegal_health.description=Markiert einen Spieler, dessen gemeldeter Gesundheitswert über seinem maximalen Gesundheitswert liegt.
module.anti_bot.fake_entity_id.name=Fake Entity ID
module.anti_bot.fake_entity_id.description=Markiert einen Spieler, dessen Entity-ID negativ oder größer als eine Milliarde ist.
module.anti_bot.duplicate_name.name=Duplicate Name
module.anti_bot.duplicate_name.description=Markiert einen Spieler, dessen Name mit dem eines anderen Online-Spielers übereinstimmt, der eine andere UUID hat.
module.anti_bot.invalid_ground.name=Invalid Ground
module.anti_bot.invalid_ground.description=Gruppiert den Schalter und die Schwelle für das Markieren von Spielern mit inkonsistenter Bewegung im Spiel.
module.anti_bot.invalid_ground.enabled.name=Enabled
module.anti_bot.invalid_ground.enabled.description=Aktiviert die Verfolgung von Spielern, die sich auf dem Spielfeld befinden, während sich ihre vertikale Position ändert.
module.anti_bot.invalid_ground.threshold.name=Threshold
module.anti_bot.invalid_ground.threshold.description=Legt fest, wie viele Verstöße gegen ungültigen Boden ein Spieler erreichen muss, bevor er markiert wird.
module.anti_bot.not_swung.name=Not Swung
module.anti_bot.not_swung.description=Gruppiert den Schalter und das Alter, um Spieler zu markieren, die nie eine Schwingungsanimation senden.
module.anti_bot.not_swung.enabled.name=Enabled
module.anti_bot.not_swung.enabled.description=Markiert Spieler, die noch nie ein Handbewegungspaket gesendet haben.
module.anti_bot.not_swung.min_age.name=Min Age
module.anti_bot.not_swung.min_age.description=Legt das minimale Alter einer Entität fest, bevor ein Spieler, der noch nie geschwungen hat, markiert werden kann.
module.anti_bot.always_in_radius.name=Always In Radius
module.anti_bot.always_in_radius.description=Gruppiert den Schalter und den Bereich für das Markieren von Spielern, die nie einen bestimmten Abstand verlassen.
module.anti_bot.always_in_radius.enabled.name=Enabled
module.anti_bot.always_in_radius.enabled.description=Markiert Spieler, die die konfigurierte Reichweite nicht verlassen haben.
module.anti_bot.always_in_radius.range.name=Range
module.anti_bot.always_in_radius.range.description=Legt die Distanz in Blöcken fest, die ein Spieler überschreiten muss, um vom Radius-Flag-Bereich freigegeben zu werden.
module.anti_bot.latency_timing.name=Latency Timing
module.anti_bot.latency_timing.description=Gruppiert den Schalter und die Schwelle für das Markieren von Spielern aufgrund verdächtiger Aktualisierungszeiten der Latenz.
module.anti_bot.latency_timing.enabled.name=Enabled
module.anti_bot.latency_timing.enabled.description=Aktiviert die Markierung von Spielern, deren Latenz innerhalb des Zeitfensters auf Null fällt.
module.anti_bot.latency_timing.threshold_ms.name=Threshold MS
module.anti_bot.latency_timing.threshold_ms.description=Legt das maximale Zeitintervall in Millisekunden fest, innerhalb dessen Latenzaktualisierungen für einen Spieler markiert werden.

# Aim Assist
module.aim_assist.name=Aim Assist
module.aim_assist.description=Hilft beim Gegner Anvisieren (Kein lock on)
module.aim_assist.mode.name=Mode
module.aim_assist.mode.description=Wählt die Korrekturstufe aus: Einfach, Fortgeschritten, Adaptiv oder Sensibilität.
module.aim_assist.silent.name=Silent
module.aim_assist.silent.description=Wendet Zielkorrekturen an, ohne die sichtbare Kamera zu bewegen; ausschalten dreht Ihre Ansicht.
module.aim_assist.targeting.name=Targeting
module.aim_assist.targeting.description=Gruppiert die Zielauswahl-Einstellungen: Körperteil, FOV, Reichweite, Geschwindigkeit und Magnet.
module.aim_assist.body_part.name=Body Part
module.aim_assist.body_part.description=Wählt aus, welchen Körperteil er ins Visier nimmt: den nächsten, den Kopf, die Brust oder die Füße.
module.aim_assist.fov.name=FOV
module.aim_assist.fov.description=Legt den Sichtkegel in Grad fest, innerhalb dessen ein Ziel ausgewählt werden kann.
module.aim_assist.range.name=Range
module.aim_assist.range.description=Legt die maximale Entfernung in Blöcken fest, in der ein Ziel ausgewählt werden kann.
module.aim_assist.speed.name=Speed
module.aim_assist.speed.description=Legt fest, wie stark die Korrektur jedes Ticks das Ziel in Prozent beeinflusst.
module.aim_assist.magnet.name=Magnet
module.aim_assist.magnet.description=Erhöht die Zugkraft, sobald Ihr Fadenkreuz sich bereits in der Nähe des Ziels befindet.
module.aim_assist.visible_smoothing.name=Visible Smoothing
module.aim_assist.visible_smoothing.description=Gruppensichtbare Zielausrichtungseinstellungen: Glättungsfaktor und maximale Drehung pro Tick.
module.aim_assist.smoothing.name=Smoothing
module.aim_assist.smoothing.description=Wie allmählich sichtbare Korrekturen verteilt werden, wird festgelegt; niedrigere Werte sorgen für einen flüssigeren Übergang.
module.aim_assist.max_rotation/tick.name=Max Rotation/Tick
module.aim_assist.max_rotation/tick.description=Wie viele Grad die sichtbare Ansicht in einem einzigen Tick gedreht werden kann.
module.aim_assist.curve.name=Curve
module.aim_assist.curve.description=Gruppiert die erweiterten Kurveneinstellungen: Kurvenglättung und Beschleunigung.
module.aim_assist.curve_smoothing.name=Curve Smoothing
module.aim_assist.curve_smoothing.description=Legt den Divisor fest, der die Korrekturkurve bestimmt; höhere Werte erleichtern die Bewegung stärker.
module.aim_assist.acceleration.name=Acceleration
module.aim_assist.acceleration.description=Legt den Kurvenexponent fest, der die Korrektur verstärkt, wenn der Zielabstand zunimmt.
module.aim_assist.randomization.name=Randomization
module.aim_assist.randomization.description=Gruppiert die Variationseinstellungen pro Tick: Geschwindigkeitsvarianz, Jitter und Überschwingen.
module.aim_assist.speed_variance.name=Speed Variance
module.aim_assist.speed_variance.description=Legt den zufälligen Plus/Minus-Bereich fest, der zur Korrekturgeschwindigkeit pro Tick hinzugefügt wird.
module.aim_assist.yaw_jitter.name=Yaw Jitter
module.aim_assist.yaw_jitter.description=Summiert sich auf diese viele Grad zufälliger horizontaler Variation bei Korrekturen.
module.aim_assist.pitch_jitter.name=Pitch Jitter
module.aim_assist.pitch_jitter.description=Summiert sich auf diese viele Grad zufälliger vertikaler Variation bei Korrekturen.
module.aim_assist.overshoot.name=Overshoot
module.aim_assist.overshoot.description=Lassen Sie Korrekturen kurzzeitig das Ziel um bis zu diesen Grad vorbeiziehen, bevor sie sich einpendeln.
module.aim_assist.adaptive.name=Adaptive
module.aim_assist.adaptive.description=Gruppiert die adaptiven Einstellungen: maximale Stärke und adaptive Empfindlichkeit.
module.aim_assist.max_strength.name=Max Strength
module.aim_assist.max_strength.description=Der Multiplikator im adaptiven Modus kann die Korrekturstärke beeinflussen.
module.aim_assist.adaptive_sensitivity.name=Adaptive Sensitivity
module.aim_assist.adaptive_sensitivity.description=Wie schnell der adaptive Modus die Stärke in Richtung des maximalen Grenzwerts anpasst, wird hier festgelegt.
module.aim_assist.sensitivity.name=Sensitivity
module.aim_assist.sensitivity.description=Gruppiert die Sensitivitätsmodus-Einstellungen: Multiplikator, Aktivierungs-FOV und Distanzskalierung.
module.aim_assist.sens_multiplier.name=Sens Multiplier
module.aim_assist.sens_multiplier.description=Multipliziert die Maus-Empfindlichkeit mit diesem Wert, während auf ein Ziel gepeilt wird.
module.aim_assist.activation_fov.name=Activation FOV
module.aim_assist.activation_fov.description=Reduzierte Empfindlichkeit gilt nur, wenn sich ein Ziel innerhalb dieses FOV-Kegels befindet.
module.aim_assist.scale_with_distance.name=Scale With Distance
module.aim_assist.scale_with_distance.description=Je näher du mit der Zielerfassung im Zentrum liegst, desto stärker wird die Reduzierung der Empfindlichkeit.
module.aim_assist.requirements.name=Requirements
module.aim_assist.requirements.description=Die Bedingungen werden gruppiert: Klick erforderlich, Waffe erforderlich, Sichtprüfung, horizontal begrenzt.
module.aim_assist.require_click.name=Require Click
module.aim_assist.require_click.description=Benötigt das Halten des Angriffs-Keys, damit die Zielhilfe Korrekturen anwendet.
module.aim_assist.require_weapon.name=Require Weapon
module.aim_assist.require_weapon.description=Eine Waffe muss gehalten werden, damit die Zielhilfe Korrekturen anwendet.
module.aim_assist.visibility_check.name=Visibility Check
module.aim_assist.visibility_check.description=Nur unterstützt Ziele, die sich nicht in deinem Sichtfeld befinden.
module.aim_assist.horizontal_only.name=Horizontal Only
module.aim_assist.horizontal_only.description=Korrekturen werden auf die horizontale Gierbewegung beschränkt, während die vertikale Nickbewegung unverändert bleibt.
module.aim_assist.draw_fov.name=Draw FOV
module.aim_assist.draw_fov.description=Zeigt einen On-Screen-Kreis, der den konfigurierten FOV-Kegel darstellt.
module.aim_assist.targets.name=Targets
module.aim_assist.targets.description=Konfiguriert, welche Entitätstypen angepeilt werden können.

# Auto Clicker
module.auto_clicker.name=Auto Clicker
module.auto_clicker.description=Klickt automatisch für dich
module.auto_clicker.mode.name=Mode
module.auto_clicker.mode.description=Wählt das Klickratenmodell: Einfach, Erweiterter Bereich oder Adaptive Selbstoptimierung.
module.auto_clicker.cps.name=CPS
module.auto_clicker.cps.description=Legt die Zielklicks pro Sekunde fest, die im einfachen Modus verwendet werden.
module.auto_clicker.cps_range.name=CPS Range
module.auto_clicker.cps_range.description=Legt die unteren und oberen Grenzen für die Klicks pro Sekunde fest, die zwischen jedem Klick zufällig variieren.
module.auto_clicker.variance_refresh.name=Variance Refresh
module.auto_clicker.variance_refresh.description=Wie viele Klicks vergehen müssen, bevor der Varianzmultiplikator der Rate neu gemischt wird.
module.auto_clicker.drops.name=Drops
module.auto_clicker.drops.description=Ermöglicht gelegentlich kurzzeitige Unterschreitungen der Ziel-Clickrate.
module.auto_clicker.drop_chance.name=Drop Chance
module.auto_clicker.drop_chance.description=Legt die prozentuale Wahrscheinlichkeit pro Klick fest, bei der eine Abwärtsrate angewendet wird.
module.auto_clicker.spikes.name=Spikes
module.auto_clicker.spikes.description=Ermöglicht gelegentlich kurze Ausbrüche über die Ziel-Klickrate hinaus.
module.auto_clicker.spike_chance.name=Spike Chance
module.auto_clicker.spike_chance.description=Legt die prozentuale Wahrscheinlichkeit pro Klick für einen Aufwärts-Rate-Schub fest.
module.auto_clicker.threshold.name=Threshold
module.auto_clicker.threshold.description=Der Trefferquote-Wert, der erreicht werden muss, bevor der adaptive Modus die Klickrate beeinflusst.
module.auto_clicker.increment.name=Increment
module.auto_clicker.increment.description=Legt fest, wie stark der adaptive Modus seine Klickrate und Punktzahl bei jeder Anpassung verändert.
module.auto_clicker.mouse_buttons.name=Mouse Buttons
module.auto_clicker.mouse_buttons.description=Wählt aus, welche Maustasten – links und rechts – der Autoklicker auslöst.
module.auto_clicker.require_pressed.name=Require Pressed
module.auto_clicker.require_pressed.description=Nur ein Autoklick simuliert einen Klick, während du die Taste physisch gedrückt hältst.
module.auto_clicker.weapons_only.name=Weapons Only
module.auto_clicker.weapons_only.description=Nur Klicks funktionieren, wenn ein Schwert oder eine Axt in der Haupt Hand gehalten wird.
module.auto_clicker.block_hit.name=Block Hit
module.auto_clicker.block_hit.description=Erlaubt dem Autoklicker, weiterzulaufen, während du ihn blockierst.
module.auto_clicker.requirements.name=Requirements
module.auto_clicker.requirements.description=Gruppiert die Klick-Bedingungen: gedrückt erforderlich, nur Waffen und Blocktreffer.

# Kill Aura
module.kill_aura.name=Kill Aura
module.kill_aura.description=Greift automatisch Gegner, Tiere und Monster für dich an
module.kill_aura.mode.name=Mode
module.kill_aura.mode.description=Wählt, ob auf ein Ziel fixiert oder zwischen Zielen nach Gesundheit und Aktualität gewechselt werden soll.
module.kill_aura.rotation_range.name=Rotation Range
module.kill_aura.rotation_range.description=Legt die maximale Distanz in Blöcken fest, in der nach einem Ziel gesucht und es ausgerichtet wird.
module.kill_aura.swing_range.name=Swing Range
module.kill_aura.swing_range.description=Legt die maximale Distanz in Blöcken fest, in der zusätzliche falsche Armschwünge ausgegeben werden.
module.kill_aura.hide_fake_swings.name=Hide Fake Swings
module.kill_aura.hide_fake_swings.description=Überspringt das Rendern falscher Schwingungen, wenn Sie nicht direkt auf ein Objekt schauen.
module.kill_aura.require_attack_key.name=Require Attack Key
module.kill_aura.require_attack_key.description=Läuft das Modul nur, solange die Angriffstaste gedrückt wird.
module.kill_aura.require_weapon.name=Require Weapon
module.kill_aura.require_weapon.description=Läuft das Modul nur, wenn ein Schwert, eine Axt oder eine Spitzhacke gehalten wird.
module.kill_aura.override_raycast.name=Override Raycast
module.kill_aura.override_raycast.description=Ersetzt dein Fadenkreuztreffergebnis durch das ausgewählte Ziel, sodass Angriffe darauf registriert werden.
module.kill_aura.tick_lookahead.name=Tick Lookahead
module.kill_aura.tick_lookahead.description=Behält die abgehende Rotation unverändert und bestätigt das Ziel mit einem Raycast, bevor es angreift.
module.kill_aura.fov.name=FOV
module.kill_aura.fov.description=Begrenzt die Zielausrichtung auf Entitäten innerhalb dieses Sichtkegelwinkels in Grad vor Ihnen.
module.kill_aura.teams.name=Team Check
module.kill_aura.teams.description=Schließt Spieler aus deinem eigenen Team von der Zielauswahl aus.
module.kill_aura.visuals.name=Visuals
module.kill_aura.visuals.description=Schaltet visuelle Indikatoren ein, einschließlich eines Rahmens um das aktuelle Ziel.
module.kill_aura.requirements.name=Requirements
module.kill_aura.requirements.description=Gruppiert die Bedingungen "Waffe halten" und "Angriffs-Taste halten", die das Modul sperren.

# Velocity
module.velocity.name=Velocity
module.velocity.description=Verringert den Rückstoß bei Treffern von Gegnern
module.velocity.mode.name=Mode
module.velocity.mode.description=Wählt aus, welcher Geschwindigkeitsreduzierungsmodus angewendet wird: Normal, Watchdog oder MushMC.

# Attack Delay
module.attack_delay.name=Attack Delay
module.attack_delay.description=Entfernt die Verzögerung nach einem verfehlten Angriff
module.attack_delay.max_cooldown.name=Max Cooldown
module.attack_delay.max_cooldown.description=Legt die Anzahl der Ticks fest, auf die die Abklingzeit des Nachfolgeantiffs begrenzt wird. 0 entfernt die Begrenzung.

# Auto Head
module.auto_head.name=Auto Head
module.auto_head.description=Isst automatisiert Golden Heads
module.auto_head.heal_delay.name=Heal Delay
module.auto_head.heal_delay.description=Stellt die Abkühlzeit in Millisekunden ein, die das Modul zwischen dem Verzehr goldener Köpfe abwartet.
module.auto_head.health.name=Health
module.auto_head.health.description=Legt den Gesundheitswert fest, bei dem oder unter dem das Modul einen goldenen Kopf frisst, um sich zu heilen.

# Block
module.block.name=Block
module.block.description=Erlaubt illegale Aktionen beim Blocken oder blockt automatisch
module.block.blocking.name=Blocking
module.block.blocking.description=Erlaubt dem Spieler, weiter zu schwingen und anzugreifen, während er blockt.
module.block.enabled.name=Enabled
module.block.enabled.description=Aktiviert automatisch das Blocken mit Schwert oder Schild, wenn sich ein Ziel in Reichweite befindet.
module.block.require_attack_key.name=Require Attack Key
module.block.require_attack_key.description=Beschränkt den Auto-Block auf das Feuern nur, solange die Angriffstaste gedrückt wird.
module.block.block_range.name=Block Range
module.block.block_range.description=Legt die Distanz in Blöcken fest, innerhalb derer ein Ziel die automatische Blockierung auslöst.
module.block.allow_swing_while....name=Allow Swing While...
module.block.allow_swing_while....description=Gruppiert den Schalter, mit dem der Spieler schwingen und angreifen kann, während er blockt.
module.block.auto_block.name=Auto Block
module.block.auto_block.description=Gruppiert den Auto-Block-Schalter sowie dessen Angriffs-Taste- und Reichweiten-Unterfunktionen.

# Lag Range
module.lag_range.name=Lag Range
module.lag_range.description=Laggt deine Packets gezielt um dir einen Lag-Vorteil zu verschaffen
module.lag_range.start_buffering_at.name=Start Buffering At
module.lag_range.start_buffering_at.description=Distanz in Blöcken zu einem Ziel, bei der ausgehende Pakete zurückgehalten werden.
module.lag_range.release_range.name=Release Range
module.lag_range.release_range.description=Die Entfernung in Blöcken zum Ziel, bei der die gehaltenen Pakete freigegeben werden.
module.lag_range.release_timer.name=Release Timer
module.lag_range.release_timer.description=Maximal lange Pakete werden vor der Freigabe zurückgehalten, unabhängig vom Bereich.
module.lag_range.release_options.name=Release Options
module.lag_range.release_options.description=Gruppiert den Freigabe-Bereich und den Freigabe-Timer, die steuern, wann gehaltene Pakete freigegeben werden.

