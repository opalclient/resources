module.animations.offset_x.description=Verschiebt das Hauptgegenstand in der Ego-Perspektive nach links oder rechts.
module.animations.offset_y.name=Offset Y
module.animations.offset_y.description=Verschiebt das Hauptgegenstand im Ego-Modus nach oben oder unten.
module.animations.swing_slowdown.name=Swing Slowdown
module.animations.swing_slowdown.description=Verlangsamt die Animation des Schwunges, wobei höhere Werte dazu führen, dass jeder Schwung länger dauert.
module.animations.old_cooldown_animation.name=Old Cooldown Animation
module.animations.old_cooldown_animation.description=Stellt die Animation des Abklingzeit-Schwingens für das Legacy-Item wieder her.
module.animations.visual_swing_on_use.name=Visual Swing on Use
module.animations.visual_swing_on_use.description=Führt eine visuelle Handbewegung aus, während ein Gegenstand benutzt wird.
module.animations.hide_drop_swing.name=Hide Drop Swing
module.animations.hide_drop_swing.description=Unterdrückt die Armbewegungsanimation, die beim Loslassen eines Gegenstands abgespielt wird.
module.animations.equip_offset.name=Equip Offset
module.animations.equip_offset.description=Ermöglicht eine Verschiebung der Ausrüstungs-(Hebungs-)Animation des Gegenstands.
module.animations.sword_blocking.name=Sword Blocking
module.animations.sword_blocking.description=Gruppiert den Schalter zum Blocken mit dem Schwert und den Auswahler für den Animationsstil.
module.animations.shields.name=Shields
module.animations.shields.description=Gruppiert die Optionen zum Ausblenden des Schilditems und des zugehörigen Schnellzugriffs für den Nebenbewaffnungsslot.
module.animations.player.name=Player
module.animations.player.description=Gruppiert die Legacy-Spieler-Körperanimationstoggles (Gehen, Schleichen, Farbgebung, Pose).
module.animations.item.name=Item
module.animations.item.description=Gruppiert die Optionen für das gehaltene Objekt bezüglich Versatz, Skalierung, Schwingung und Ausrüstungsanimationen.

# Ambience
module.ambience.name=Ambience
module.ambience.description=Ändert die Tageszeit
module.ambience.use_real_time.name=Use Real Time
module.ambience.use_real_time.description=Ermittelt die Tageszeit der Welt anhand der lokalen Systemuhr Ihres Computers bei jedem Tick.
module.ambience.time.name=Time
module.ambience.time.description=Legt die feste Tageszeit fest, die auf die Welt aufgezwungen wird, in Minecraft-Ticks (0-23450).
module.ambience.end_sky.name=End Sky
module.ambience.end_sky.description=Ersetzt den Himmel durch den Sternenhimmel des End-Dimensions-Skybox, während das Modul aktiv ist.

# Overlay
module.overlay.name=Overlay
module.overlay.description=Zeigt das Interface von dem Client wie Watermark oder Modulliste
