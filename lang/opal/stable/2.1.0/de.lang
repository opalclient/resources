module.clipper.name=Clipper
module.clipper.description=Clippt dich durch Blöcke nach oben oder unten wenn möglich
module.clipper.limit_distance.name=Limit Distance
module.clipper.limit_distance.description=Begrenze den Auf- und Ab-Scan auf etwa zehn Blöcke anstatt bis zur Weltbauhöhe zu reichen.
module.clipper.upwards.name=Upwards
module.clipper.upwards.description=Ermöglicht das Scannen und das Anclippen bis zur nächsten Plattform über Ihnen, während Sie sich am Boden befinden.

# Flight
module.flight.name=Flight
module.flight.description=Gibt dir die Fähigkeit zu fliegen
module.flight.mode.name=Mode
module.flight.mode.description=Wählt die Flugstrategie: Vanilla Freiflug, Feuerball Gleitflug oder Luftlauf.

# Long Jump
module.long_jump.name=Long Jump
module.long_jump.description=Erlaubt es dir weiter zu springen
module.long_jump.mode.name=Mode
module.long_jump.mode.description=Wählt die Starttechnik aus, mit der das Modul dich weiter vorwärts katapultiert.

# No Slow
module.no_slow.name=No Slow
module.no_slow.description=Kein Verlangsamen beim Nutzen von Gegenständen
module.no_slow.mode.name=Mode
module.no_slow.mode.description=Wählt aus, welche Strategie zur Verlangsamungsbeseitigung das Modul anwendet, während Sie ein Element verwenden.
module.no_slow.allow_sprinting.name=Allow Sprinting
module.no_slow.allow_sprinting.description=Behält deine Sprintgeschwindigkeit bei, während du ein Item benutzt, anstatt die Gehgeschwindigkeit anzunehmen.

# Movement Recorder
module.movement_recorder.name=Movement Recorder
module.movement_recorder.description=Nimmt deine Bewegungen auf und spielt sie wieder ab
module.movement_recorder.show_breadcrumbs.name=Show Breadcrumbs
module.movement_recorder.show_breadcrumbs.description=Zeichnet eine Krummelspur, die den aufgezeichneten Pfad durch die Welt verfolgt.
module.movement_recorder.show_block_highlights.name=Show Block Highlights
module.movement_recorder.show_block_highlights.description=Markiert die Start- und Endblöcke der Aufnahme mit ausblendenden Highlights in der Welt.
module.movement_recorder.dynamic_island.name=Dynamic Island
module.movement_recorder.dynamic_island.description=Zeigt das dynamische Insel-Steuerungselement des Aufnahmegeräts während der Aufnahme oder Wiedergabe an.
module.movement_recorder.mode.name=Mode
module.movement_recorder.mode.description=Wählt aus, ob der Recorder Bewegungen aufzeichnet oder abspielt.
module.movement_recorder.loop_playback.name=Loop Playback
module.movement_recorder.loop_playback.description=Startet die Wiedergabe vom Anfang neu, wenn die Aufnahme beendet ist.
module.movement_recorder.teleport_to_start.name=Teleport to Start
module.movement_recorder.teleport_to_start.description=Setzt Ihre Position direkt auf den Startpunkt der Aufnahme, wenn die Wiedergabe beginnt.
module.movement_recorder.wait_for_position.name=Wait for Position
module.movement_recorder.wait_for_position.description=Wartet, bis du den Startpunkt erreichst, bevor die Wiedergabe beginnt.
module.movement_recorder.rotation_speed.name=Rotation Speed
module.movement_recorder.rotation_speed.description=Legt fest, wie schnell sich Ihre Ansicht während der Wiedergabe zu aufgezeichneten Winkeln dreht.
module.movement_recorder.default_name.name=Default Name
module.movement_recorder.default_name.description=Legt den Standardnamen für neu gespeicherte Aufnahmen fest.
module.movement_recorder.path_detail.name=Path Detail
