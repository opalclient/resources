module.piercing.name=Piercing
module.piercing.description=Interagiere durch bestimmtes durch

# Reach
module.reach.name=Reach
module.reach.description=Erlaubt es dir weiter zu interagieren oder anzugreifen
module.reach.entity_interaction_range.name=Entity Interaction Range
module.reach.entity_interaction_range.description=Legt die maximale Distanz in Blöcken fest, in der du Kreaturen angreifen oder mit ihnen interagieren kannst.
module.reach.block_interaction_range.name=Block Interaction Range
module.reach.block_interaction_range.description=Legt die maximale Distanz in Blöcken fest, in der du mit Blöcken interagieren kannst.

# TP Aura
module.tp_aura.name=TP Aura
module.tp_aura.description=Teleportiert dich zu Gegnern und greift sie an

# WTap
module.wtap.name=WTap
module.wtap.description=Lässt W los um mehr Rückstoß zu geben
module.wtap.chance.name=Chance
module.wtap.chance.description=Prozentuale Wahrscheinlichkeit, dass ein Angriff die Freigabe der Vorwärtstaste auslöst.
module.wtap.delay_ticks.name=Delay Ticks
module.wtap.delay_ticks.description=Anzahl der Ticks, die nach dem Angriff gewartet werden müssen, bevor die Vorwärts-Taste losgelassen wird.
module.wtap.release_ticks.name=Release Ticks
module.wtap.release_ticks.description=Anzahl der Ticks, während der die Vorwärtstaste gedrückt bleibt, bevor die Bewegung wieder aufgenommen wird.
module.wtap.only_sprinting.name=Only Sprinting
module.wtap.only_sprinting.description=Löst die Freigabe nur aus, während der Spieler sprintet.
module.wtap.only_ground.name=Only Ground
module.wtap.only_ground.description=Löst den Effekt nur aus, wenn sich der Spieler auf dem Boden befindet.

